---
// Hidden page — Recursive Hall renderer
// Accessible via Konami code or direct URL
import Base from '../layouts/Base.astro';
---

<Base title="recursive hall" description="Seeded procedural architecture rendered as wireframe ink drawings.">
  <div class="hall-wrap" id="cvWrap">
    <canvas id="cv"></canvas>
  </div>
  <div class="hall-controls">
    <button class="hall-btn" id="hall-back" onclick="window.location.href='/'">back to site</button>
    <button class="hall-btn" id="hall-random" onclick="randomSeed()">random seed</button>
    <div class="hall-info">
      <span id="hall-seed">seed: 42</span>
      <span id="hall-fps"></span>
    </div>
  </div>
  <div class="hall-hint" id="hint">click to look around / WASD to move / ESC to release</div>

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script is:inline define:vars={{}} >
    // Embedded Recursive Hall renderer — adapted from recursive-hall-v4-renderer.html
    const P = {seed:42, depth:5, decay:0.58, cw:400, ch:280, corr:600, nP:250, fog:50, grain:40, bleed:30, lineW:1.0, spd:1.0, sens:0.3};
    let mode = 'free', theme = 'dark';
    let yaw = 0, pitch = 0;
    let camPos = new THREE.Vector3(0, -8, 150);
    let camVel = new THREE.Vector3();
    const keys = {};
    let isLocked = false;
    let renderer, scene, camera, hallMesh, partPoints, glowPoints;
    let partPos, partCol, partLife, partMaxLife, partPhase, partSpd, partRz, partVx, partVy;
    let fC = 0, fT = 0, fV = 0, t = 0;
    let sceneRT, brightRT, blurRT_A, blurRT_B;
    let postScene, postCamera, postQuad;
    let brightMat, blurMat, compositeMat;
    let particleSprite;
    let _s = 42;
    function srand(s) { _s = s; }
    function rand() { _s = (_s * 16807 + 0) % 2147483647; return (_s & 0x7fffffff) / 2147483647; }
    function rr(a, b) { return a + rand() * (b - a); }

    function getBg() { return 0x050505; }
    function getInk() { return [1,1,1]; }
    function getInkDim() { return [0.5,0.5,0.5]; }
    function getInkFaint() { return [0.18,0.18,0.18]; }
    function getWarmTint() { return [1.0,0.9,0.65]; }
    function getCoolTint() { return [0.55,0.5,1.0]; }
    function getGlowColor() { return [1.0,0.85,0.5]; }
    function getPartColor() { return [1.0,0.9,0.7]; }
    function getFogVec() { return [0.03,0.02,0.04]; }

    const FULLSCREEN_VERT = `varying vec2 vUv; void main() { vUv = uv; gl_Position = vec4(position, 1.0); }`;
    const HALL_VERT = `attribute vec3 color; varying vec3 vColor; varying float vDepth; uniform float time;
    void main() { vec3 pos = position; float wave = sin(time*0.4+pos.z*0.008+pos.y*0.01)*2.5; pos.x += wave;
    pos.y += cos(time*0.3+pos.z*0.006)*1.5; vec4 mvPos = modelViewMatrix*vec4(pos,1.0); vDepth = -mvPos.z;
    vColor = color; gl_Position = projectionMatrix*mvPos; }`;
    const HALL_FRAG = `varying vec3 vColor; varying float vDepth; uniform float time; uniform vec3 warmTint;
    uniform vec3 coolTint; uniform float fogDensity; uniform vec3 fogColor;
    void main() { float depthT = smoothstep(0.0,3500.0,vDepth); vec3 tint = mix(warmTint,coolTint,depthT);
    float shimmer = 0.92+0.08*sin(time*1.5+vDepth*0.003); vec3 col = vColor*tint*shimmer;
    float fog = exp(-fogDensity*vDepth); col = mix(fogColor,col,fog);
    gl_FragColor = vec4(col, mix(0.4,0.92,fog)); }`;
    const BRIGHT_FRAG = `uniform sampler2D tDiffuse; uniform float threshold; uniform float isDark; varying vec2 vUv;
    void main() { vec4 c = texture2D(tDiffuse,vUv); float l = dot(c.rgb,vec3(0.299,0.587,0.114));
    float soft = smoothstep(threshold,threshold+0.2,l); gl_FragColor = c*soft; }`;
    const BLUR_FRAG = `uniform sampler2D tDiffuse; uniform vec2 direction; uniform vec2 resolution; varying vec2 vUv;
    void main() { vec2 px = direction/resolution; vec4 sum = vec4(0.0);
    sum += texture2D(tDiffuse,vUv-4.0*px)*0.0162; sum += texture2D(tDiffuse,vUv-3.0*px)*0.0540;
    sum += texture2D(tDiffuse,vUv-2.0*px)*0.1216; sum += texture2D(tDiffuse,vUv-1.0*px)*0.1945;
    sum += texture2D(tDiffuse,vUv)*0.2270; sum += texture2D(tDiffuse,vUv+1.0*px)*0.1945;
    sum += texture2D(tDiffuse,vUv+2.0*px)*0.1216; sum += texture2D(tDiffuse,vUv+3.0*px)*0.0540;
    sum += texture2D(tDiffuse,vUv+4.0*px)*0.0162; gl_FragColor = sum; }`;
    const COMPOSITE_FRAG = `uniform sampler2D tScene; uniform sampler2D tBloom; uniform float bloomStrength;
    uniform float grainAmount; uniform float vignetteStrength; uniform float isDark; uniform float time;
    uniform vec2 resolution; varying vec2 vUv;
    float hash(vec2 p) { vec3 p3 = fract(vec3(p.xyx)*vec3(0.1031,0.1030,0.0973));
    p3 += dot(p3,p3.yzx+33.33); return fract((p3.x+p3.y)*p3.z); }
    void main() { vec4 sc = texture2D(tScene,vUv); vec4 bl = texture2D(tBloom,vUv);
    vec3 color = sc.rgb + bl.rgb*bloomStrength;
    vec2 grainUv = gl_FragCoord.xy+vec2(time*173.13,time*89.71);
    float grain = (hash(grainUv)-0.5)*grainAmount; color += grain;
    vec2 center = vUv-0.5; float aspect = resolution.x/resolution.y;
    float dist = length(center*vec2(aspect,1.0))/(0.5*aspect);
    float vigMask = smoothstep(0.35,1.05,dist)*vignetteStrength;
    color *= (1.0-vigMask);
    float lum = dot(color,vec3(0.299,0.587,0.114));
    color *= mix(vec3(0.92,0.95,1.08),vec3(1.08,1.02,0.94),lum);
    gl_FragColor = vec4(clamp(color,0.0,1.0),1.0); }`;

    function init() {
      const wrap = document.getElementById('cvWrap');
      const cv = document.getElementById('cv');
      const W = wrap.offsetWidth, H = wrap.offsetHeight;
      renderer = new THREE.WebGLRenderer({canvas:cv, antialias:true});
      renderer.setSize(W,H); renderer.setPixelRatio(Math.min(window.devicePixelRatio,1.5));
      renderer.setClearColor(getBg());
      scene = new THREE.Scene(); scene.fog = new THREE.FogExp2(getBg(), 0.0006+P.fog*0.00004);
      camera = new THREE.PerspectiveCamera(68, W/H, 1, 12000); camera.position.copy(camPos);
      setupPostProcessing(W,H); createParticleSprite(); rebuild(); setupControls(); animate();
    }

    function setupPostProcessing(W,H) {
      const opts = {minFilter:THREE.LinearFilter,magFilter:THREE.LinearFilter,format:THREE.RGBAFormat};
      const pW = Math.floor(W/2), pH = Math.floor(H/2);
      sceneRT = new THREE.WebGLRenderTarget(W,H,opts);
      brightRT = new THREE.WebGLRenderTarget(pW,pH,opts);
      blurRT_A = new THREE.WebGLRenderTarget(pW,pH,opts);
      blurRT_B = new THREE.WebGLRenderTarget(pW,pH,opts);
      postScene = new THREE.Scene();
      postCamera = new THREE.OrthographicCamera(-1,1,1,-1,0,1);
      postQuad = new THREE.Mesh(new THREE.PlaneBufferGeometry(2,2));
      postQuad.frustumCulled = false; postScene.add(postQuad);
      brightMat = new THREE.ShaderMaterial({uniforms:{tDiffuse:{value:null},threshold:{value:0.06},isDark:{value:1.0}},
        vertexShader:FULLSCREEN_VERT,fragmentShader:BRIGHT_FRAG,depthTest:false,depthWrite:false});
      blurMat = new THREE.ShaderMaterial({uniforms:{tDiffuse:{value:null},direction:{value:new THREE.Vector2(1,0)},
        resolution:{value:new THREE.Vector2(pW,pH)}},vertexShader:FULLSCREEN_VERT,fragmentShader:BLUR_FRAG,depthTest:false,depthWrite:false});
      compositeMat = new THREE.ShaderMaterial({uniforms:{tScene:{value:null},tBloom:{value:null},bloomStrength:{value:0.5},
        grainAmount:{value:0.06},vignetteStrength:{value:0.6},isDark:{value:1.0},time:{value:0},
        resolution:{value:new THREE.Vector2(W,H)}},vertexShader:FULLSCREEN_VERT,fragmentShader:COMPOSITE_FRAG,depthTest:false,depthWrite:false});
    }

    function createParticleSprite() {
      const size=64,c=document.createElement('canvas'); c.width=size;c.height=size;
      const ctx=c.getContext('2d'),g=ctx.createRadialGradient(size/2,size/2,0,size/2,size/2,size/2);
      g.addColorStop(0,'rgba(255,255,255,1)'); g.addColorStop(0.1,'rgba(255,255,255,0.9)');
      g.addColorStop(0.4,'rgba(255,255,255,0.2)'); g.addColorStop(1,'rgba(255,255,255,0)');
      ctx.fillStyle=g; ctx.fillRect(0,0,size,size); particleSprite=new THREE.CanvasTexture(c);
    }

    function setupControls() {
      const wrap = document.getElementById('cvWrap');
      wrap.addEventListener('click', () => { if(!isLocked) wrap.requestPointerLock(); });
      document.addEventListener('pointerlockchange', () => {
        isLocked = !!document.pointerLockElement;
        document.getElementById('hint').style.opacity = isLocked?'0':'1';
      });
      document.addEventListener('mousemove', (e) => {
        if(!isLocked) return;
        yaw -= e.movementX*P.sens*0.004; pitch -= e.movementY*P.sens*0.004;
        pitch = Math.max(-Math.PI*0.45, Math.min(Math.PI*0.45, pitch));
      });
      document.addEventListener('keydown', (e) => { keys[e.code]=true;
        if(['KeyW','KeyA','KeyS','KeyD','Space'].includes(e.code)) e.preventDefault(); });
      document.addEventListener('keyup', (e) => { keys[e.code]=false; });
    }

    function updateCamera(dt) {
      const speed = P.spd*3.0*dt; const dir = new THREE.Vector3();
      if(keys['KeyW']){dir.x-=Math.sin(yaw)*speed;dir.z-=Math.cos(yaw)*speed;}
      if(keys['KeyS']){dir.x+=Math.sin(yaw)*speed;dir.z+=Math.cos(yaw)*speed;}
      if(keys['KeyA']){dir.x-=Math.cos(yaw)*speed;dir.z+=Math.sin(yaw)*speed;}
      if(keys['KeyD']){dir.x+=Math.cos(yaw)*speed;dir.z-=Math.sin(yaw)*speed;}
      if(keys['Space']){dir.y+=speed;} if(keys['ShiftLeft']||keys['ShiftRight']){dir.y-=speed;}
      const smooth=1-Math.pow(1-0.2,dt); camVel.lerp(dir,smooth); camPos.add(camVel);
      camera.position.copy(camPos);
      const lookAt = new THREE.Vector3(camPos.x-Math.sin(yaw)*Math.cos(pitch),
        camPos.y+Math.sin(pitch), camPos.z-Math.cos(yaw)*Math.cos(pitch));
      camera.lookAt(lookAt);
    }

    function rebuild() {
      srand(P.seed); t=0;
      if(hallMesh){scene.remove(hallMesh);hallMesh.geometry.dispose();hallMesh.material.dispose();}
      if(partPoints){scene.remove(partPoints);partPoints.geometry.dispose();partPoints.material.dispose();}
      if(glowPoints){scene.remove(glowPoints);glowPoints.geometry.dispose();glowPoints.material.dispose();glowPoints=null;}
      const verts=[],colors=[];
      const ink=getInk(),inkD=getInkDim(),inkF=getInkFaint();
      const numSegs=9; let driftX=0; const maxDrift=P.cw*0.15; const segInfo=[];
      for(let seg=0;seg<numSegs;seg++){
        srand(P.seed*7919+seg*4729);
        const wS=0.88+rand()*0.24,hS=0.92+rand()*0.16,isC=rand()<0.25,cM=isC?1.25:1.0;
        const fW=P.cw*wS*cM,fH=P.ch*hS,prevDX=driftX;
        driftX=Math.max(-maxDrift,Math.min(maxDrift,driftX+(rand()-0.5)*P.cw*0.08));
        const sZ=P.corr-seg*P.corr;
        segInfo.push({cx:driftX,w:fW,h:fH,z:sZ,prevCx:prevDX,isChamber:isC});
        const bM=isC?1.15:(0.9+rand()*0.1); const sL=[];
        buildRecurse(sL,driftX,0,sZ,fW,fH,P.corr,0,P.depth);
        for(const L of sL){
          const lJ=0.85+rand()*0.3,b=Math.min(L[6]*bM*lJ,1.0);
          let jx1=0,jy1=0,jx2=0,jy2=0;
          if(L[6]<0.5){const jA=1.5;jx1=(rand()-0.5)*jA*2;jy1=(rand()-0.5)*jA*2;jx2=(rand()-0.5)*jA*2;jy2=(rand()-0.5)*jA*2;}
          verts.push(L[0]+jx1,L[1]+jy1,L[2],L[3]+jx2,L[4]+jy2,L[5]);
          let r,g,bb;
          if(b>0.6){r=ink[0]*b;g=ink[1]*b;bb=ink[2]*b;}
          else if(b>0.25){r=inkD[0]*b*1.5;g=inkD[1]*b*1.5;bb=inkD[2]*b*1.5;}
          else{r=inkF[0]*b*2;g=inkF[1]*b*2;bb=inkF[2]*b*2;}
          colors.push(r,g,bb,r,g,bb);
        }
        const aZ=sZ-P.corr*(0.3+rand()*0.4),aw=fW*0.48,ah=fH*0.48,aR=(rand()-0.5)*0.3,aB=isC?0.16:0.12;
        for(let k=0;k<20;k++){
          const a1=-Math.PI+k/20*Math.PI,a2=-Math.PI+(k+1)/20*Math.PI;
          verts.push(driftX+Math.cos(a1)*aw,Math.sin(a1)*ah,aZ+Math.sin(a1+aR)*3,
            driftX+Math.cos(a2)*aw,Math.sin(a2)*ah,aZ+Math.sin(a2+aR)*3);
          colors.push(inkD[0]*aB,inkD[1]*aB,inkD[2]*aB,inkD[0]*aB,inkD[1]*aB,inkD[2]*aB);
        }
      }
      for(let seg=1;seg<segInfo.length;seg++){
        const prev=segInfo[seg-1],curr=segInfo[seg],jZ=curr.z;
        const phw=prev.w/2,phh=prev.h/2,chw=curr.w/2,chh=curr.h/2,rb=0.15;
        const corners=[[prev.cx-phw,-phh,curr.cx-chw,-chh],[prev.cx+phw,-phh,curr.cx+chw,-chh],
          [prev.cx-phw,phh,curr.cx-chw,chh],[prev.cx+phw,phh,curr.cx+chw,chh]];
        for(const[sx,sy,ex,ey]of corners){verts.push(sx,sy,jZ,ex,ey,jZ);
          colors.push(inkF[0]*rb,inkF[1]*rb,inkF[2]*rb,inkF[0]*rb,inkF[1]*rb,inkF[2]*rb);}
      }
      const hw=P.cw*0.5,hh=P.ch*0.5,bLen=P.corr*numSegs,gb2=0.06;
      for(const c of[[-hw,-hh],[hw,-hh],[-hw,hh],[hw,hh]]){
        verts.push(c[0],c[1],P.corr,c[0],c[1],-bLen);
        colors.push(inkF[0]*gb2,inkF[1]*gb2,inkF[2]*gb2,inkF[0]*gb2,inkF[1]*gb2,inkF[2]*gb2);
      }
      const geo=new THREE.BufferGeometry();
      geo.setAttribute('position',new THREE.Float32BufferAttribute(verts,3));
      geo.setAttribute('color',new THREE.Float32BufferAttribute(colors,3));
      const warm=getWarmTint(),cool=getCoolTint(),fogC=getFogVec();
      const mat=new THREE.ShaderMaterial({uniforms:{time:{value:0},
        warmTint:{value:new THREE.Vector3(warm[0],warm[1],warm[2])},
        coolTint:{value:new THREE.Vector3(cool[0],cool[1],cool[2])},
        fogDensity:{value:0.00015+P.fog*0.000008},
        fogColor:{value:new THREE.Vector3(fogC[0],fogC[1],fogC[2])}},
        vertexShader:HALL_VERT,fragmentShader:HALL_FRAG,transparent:true,depthWrite:false,fog:false});
      hallMesh=new THREE.LineSegments(geo,mat); scene.add(hallMesh);
      buildGlowNodes(segInfo); buildParticles();
      scene.fog.color.set(getBg()); scene.fog.density=0.0004+P.fog*0.00005; renderer.setClearColor(getBg());
      document.getElementById('hall-seed').textContent='seed: '+P.seed;
    }

    function buildRecurse(out,cx,cy,cz,w,h,d,lev,maxLev){
      if(lev>maxLev)return;
      const hw=w/2,hh=h/2,z0=cz,z1=cz-d,b=1.0-lev/maxLev*0.7;
      out.push([cx-hw,cy-hh,z0,cx-hw,cy-hh,z1,b]);out.push([cx+hw,cy-hh,z0,cx+hw,cy-hh,z1,b]);
      out.push([cx-hw,cy+hh,z0,cx-hw,cy+hh,z1,b]);out.push([cx+hw,cy+hh,z0,cx+hw,cy+hh,z1,b]);
      out.push([cx-hw,cy-hh,z0,cx+hw,cy-hh,z0,b]);out.push([cx+hw,cy-hh,z0,cx+hw,cy+hh,z0,b]);
      out.push([cx+hw,cy+hh,z0,cx-hw,cy+hh,z0,b]);out.push([cx-hw,cy+hh,z0,cx-hw,cy-hh,z0,b]);
      out.push([cx-hw,cy-hh,z1,cx+hw,cy-hh,z1,b]);out.push([cx+hw,cy-hh,z1,cx+hw,cy+hh,z1,b]);
      out.push([cx+hw,cy+hh,z1,cx-hw,cy+hh,z1,b]);out.push([cx-hw,cy+hh,z1,cx-hw,cy-hh,z1,b]);
      if(lev===0){for(let i=1;i<=2;i++){const zz=z0+(z1-z0)*i/3;
        out.push([cx-hw,cy+hh,zz,cx+hw,cy+hh,zz,b*0.28]);out.push([cx-hw,cy-hh,zz,cx+hw,cy-hh,zz,b*0.28]);
        out.push([cx-hw,cy-hh,zz,cx-hw,cy+hh,zz,b*0.16]);out.push([cx+hw,cy-hh,zz,cx+hw,cy+hh,zz,b*0.16]);}}
      if(lev<maxLev){const xb=b*0.08;out.push([cx-hw*0.8,cy-hh*0.8,z1,cx+hw*0.8,cy+hh*0.8,z1,xb]);
        out.push([cx+hw*0.8,cy-hh*0.8,z1,cx-hw*0.8,cy+hh*0.8,z1,xb]);}
      const nw=w*P.decay,nh=h*P.decay,nd=d*P.decay;
      buildRecurse(out,cx,cy+(h-nh)*0.1,z1,nw,nh,nd,lev+1,maxLev);
      if(lev<2&&lev+2<=maxLev){const ss=P.decay*0.5,sw=w*ss,sh=h*ss,sd=d*ss*0.4,midZ=(z0+z1)/2;
        buildRecurse(out,cx-hw-sw*0.35,cy,midZ,sw,sh,sd,lev+2,maxLev);
        buildRecurse(out,cx+hw+sw*0.35,cy,midZ,sw,sh,sd,lev+2,maxLev);}
    }

    function buildGlowNodes(segInfo){
      const gc=getGlowColor(),positions=[],colors=[],sizes=[],phases=[];
      for(let i=0;i<segInfo.length;i++){const seg=segInfo[i];
        if(seg.isChamber){const midZ=seg.z-P.corr*0.5;positions.push(seg.cx,0,midZ);
          colors.push(gc[0],gc[1],gc[2]);sizes.push(35);phases.push(i*1.7);}
        if(i%2===0&&i>0){positions.push(seg.cx,0,seg.z);colors.push(gc[0]*0.7,gc[1]*0.7,gc[2]*0.7);
          sizes.push(20);phases.push(i*2.3);}}
      if(positions.length===0)return;
      const geo=new THREE.BufferGeometry();
      geo.setAttribute('position',new THREE.Float32BufferAttribute(positions,3));
      geo.setAttribute('color',new THREE.Float32BufferAttribute(colors,3));
      const glowMat=new THREE.PointsMaterial({size:30,map:particleSprite,vertexColors:true,
        transparent:true,opacity:0.35,depthWrite:false,sizeAttenuation:true,blending:THREE.AdditiveBlending});
      glowPoints=new THREE.Points(geo,glowMat); scene.add(glowPoints);
    }

    function buildParticles(){
      const n=P.nP; partPos=new Float32Array(n*3); partCol=new Float32Array(n*3);
      partLife=new Float32Array(n); partMaxLife=new Float32Array(n); partPhase=new Float32Array(n);
      partSpd=new Float32Array(n); partRz=new Float32Array(n); partVx=new Float32Array(n); partVy=new Float32Array(n);
      for(let i=0;i<n;i++) resetPart(i,true);
      const geo=new THREE.BufferGeometry();
      geo.setAttribute('position',new THREE.Float32BufferAttribute(partPos,3));
      geo.setAttribute('color',new THREE.Float32BufferAttribute(partCol,3));
      const ptMat=new THREE.PointsMaterial({size:10,map:particleSprite,vertexColors:true,
        transparent:true,opacity:0.5,depthWrite:false,sizeAttenuation:true,blending:THREE.AdditiveBlending});
      partPoints=new THREE.Points(geo,ptMat); scene.add(partPoints);
    }

    function resetPart(i,init){
      const spread=P.cw*0.65,spreadY=P.ch*0.45;
      partPos[i*3]=rr(-spread,spread); partPos[i*3+1]=rr(-spreadY,spreadY);
      partRz[i]=init?-rr(50,P.corr*2.2):-P.corr*0.5-rr(0,P.corr*1.8);
      partPos[i*3+2]=camPos.z+partRz[i]; partVx[i]=rr(-0.1,0.1); partVy[i]=rr(-0.06,0.06);
      partPhase[i]=rr(0,6.28); partSpd[i]=rr(0.3,0.9);
      const life=rr(250,500)|0; partLife[i]=life; partMaxLife[i]=life;
      const pc=getPartColor(),bright=rr(0.2,0.5);
      partCol[i*3]=pc[0]*bright; partCol[i*3+1]=pc[1]*bright; partCol[i*3+2]=pc[2]*bright;
    }

    function updateParts(){
      const n=P.nP,pos=partPoints.geometry.attributes.position.array,col=partPoints.geometry.attributes.color.array;
      const fogMax=P.corr*2.2,fogPow=1+P.fog*0.022;
      for(let i=0;i<n;i++){
        const tl=t*0.007*partSpd[i];
        pos[i*3]+=partVx[i]+Math.sin(tl+partPhase[i])*0.25;
        pos[i*3+1]+=partVy[i]+Math.cos(tl*0.7+partPhase[i])*0.15;
        partRz[i]+=0.025; pos[i*3+2]=camPos.z+partRz[i]; partLife[i]--;
        if(partLife[i]<=0||partRz[i]>180){resetPart(i,false);
          pos[i*3]=partPos[i*3];pos[i*3+1]=partPos[i*3+1];pos[i*3+2]=partPos[i*3+2];continue;}
        const dist=Math.abs(partRz[i]); let ff=1-Math.min(dist/fogMax,1); ff=Math.pow(ff,fogPow);
        const life=partLife[i],ml=partMaxLife[i];
        const lf=life<30?life/30:(life>ml-20?(ml-life)/20:1); const fade=ff*lf;
        col[i*3]=partCol[i*3]*fade; col[i*3+1]=partCol[i*3+1]*fade; col[i*3+2]=partCol[i*3+2]*fade;
      }
      partPoints.geometry.attributes.position.needsUpdate=true;
      partPoints.geometry.attributes.color.needsUpdate=true;
    }

    function renderPipeline(){
      renderer.setRenderTarget(sceneRT); renderer.render(scene,camera);
      postQuad.material=brightMat; brightMat.uniforms.tDiffuse.value=sceneRT.texture;
      renderer.setRenderTarget(brightRT); renderer.render(postScene,postCamera);
      postQuad.material=blurMat;
      blurMat.uniforms.tDiffuse.value=brightRT.texture; blurMat.uniforms.direction.value.set(1,0);
      renderer.setRenderTarget(blurRT_A); renderer.render(postScene,postCamera);
      blurMat.uniforms.tDiffuse.value=blurRT_A.texture; blurMat.uniforms.direction.value.set(0,1);
      renderer.setRenderTarget(blurRT_B); renderer.render(postScene,postCamera);
      blurMat.uniforms.tDiffuse.value=blurRT_B.texture; blurMat.uniforms.direction.value.set(2.5,0);
      renderer.setRenderTarget(blurRT_A); renderer.render(postScene,postCamera);
      blurMat.uniforms.tDiffuse.value=blurRT_A.texture; blurMat.uniforms.direction.value.set(0,2.5);
      renderer.setRenderTarget(blurRT_B); renderer.render(postScene,postCamera);
      postQuad.material=compositeMat;
      compositeMat.uniforms.tScene.value=sceneRT.texture; compositeMat.uniforms.tBloom.value=blurRT_B.texture;
      compositeMat.uniforms.bloomStrength.value=P.bleed*0.025; compositeMat.uniforms.grainAmount.value=P.grain*0.0013;
      compositeMat.uniforms.vignetteStrength.value=0.55+P.fog*0.003;
      compositeMat.uniforms.isDark.value=1.0; compositeMat.uniforms.time.value=t*0.1;
      renderer.setRenderTarget(null); renderer.render(postScene,postCamera);
    }

    let lastTime = performance.now();
    function animate(){
      requestAnimationFrame(animate);
      const now=performance.now(),dt=Math.min((now-lastTime)/16.67,3); lastTime=now;
      fC++; if(now-fT>600){fV=Math.round(fC/((now-fT)/1000));fC=0;fT=now;}
      const fpsEl=document.getElementById('hall-fps'); if(fpsEl) fpsEl.textContent=fV+' fps';
      updateCamera(dt);
      if(hallMesh){hallMesh.position.z=Math.floor(-camPos.z/P.corr)*P.corr;
        hallMesh.material.uniforms.time.value=t*0.016;}
      if(glowPoints){glowPoints.position.z=hallMesh.position.z;
        glowPoints.material.opacity=0.3+Math.sin(t*0.013)*0.1;}
      if(partPoints)updateParts();
      const baseFog=0.0004+P.fog*0.00005;
      scene.fog.density=baseFog+Math.sin(t*0.005)*baseFog*0.08;
      renderPipeline(); t++;
    }

    window.randomSeed = function() {
      P.seed = Math.floor(Math.random()*999999)+1; rebuild();
    };

    window.addEventListener('resize', () => {
      const W=document.getElementById('cvWrap').offsetWidth,H=document.getElementById('cvWrap').offsetHeight;
      renderer.setSize(W,H); camera.aspect=W/H; camera.updateProjectionMatrix();
      const pW=Math.floor(W/2),pH=Math.floor(H/2);
      sceneRT.setSize(W,H); brightRT.setSize(pW,pH); blurRT_A.setSize(pW,pH); blurRT_B.setSize(pW,pH);
      blurMat.uniforms.resolution.value.set(pW,pH); compositeMat.uniforms.resolution.value.set(W,H);
    });

    window.addEventListener('load', init);
  </script>
</Base>


---
import Page from '../../layouts/Page.astro';
import { glossary } from '../../data/glossary';

const sortedEntries = Object.entries(glossary).sort((a, b) =>
  a[1].term.localeCompare(b[1].term)
);

const currentPath = Astro.url.pathname;
---

<Page title="misc -- alexander campos" description="Glossary, graveyard, and other odds and ends.">
  <article>
    <nav class="subnav" aria-label="Misc sections">
      <a href="/misc" class:list={[{ active: currentPath === '/misc' || currentPath === '/misc/' }]}>glossary</a>
      <span class="subnav-sep">/</span>
      <a href="/misc/hall-of-shame" class:list={[{ active: currentPath.startsWith('/misc/hall-of-shame') }]}>hall of shame</a>
    </nav>

    <h1>Glossary</h1>

    <p class="intro">
      WTF does this mean. I say a lot. I try to be technical where I can. I'm learning - it's okay if you are too.
    </p>

    <dl class="glossary-list">
      {sortedEntries.map(([slug, entry]) => (
        <div class="glossary-entry" id={`gloss-${slug}`}>
          <dt>{entry.term}</dt>
          <dd>{entry.definition}</dd>
        </div>
      ))}
    </dl>
  </article>
</Page>

<style>
  .subnav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    margin-bottom: 2rem;
    color: var(--white-30);
  }

  .subnav a {
    color: var(--white-45);
    text-decoration: none;
    border-bottom: none;
    transition: color 0.2s;
  }

  .subnav a:hover {
    color: var(--gold-accent);
  }

  .subnav a.active {
    color: var(--glow);
  }

  .subnav-sep {
    color: var(--white-20);
  }

  h1 {
    margin-bottom: 0.5rem;
  }

  .intro {
    margin-bottom: 2.5rem;
    color: var(--white-60);
    line-height: 1.65;
  }

  .glossary-list {
    margin-top: 1.5rem;
  }

  .glossary-entry {
    margin-bottom: 1.75rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--white-08);
    scroll-margin-top: 5rem;
  }

  .glossary-entry:last-child {
    border-bottom: none;
  }

  dt {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--gold-accent);
    margin-bottom: 0.4rem;
  }

  dd {
    color: var(--glow);
    line-height: 1.65;
    margin: 0;
  }
</style>

---
// Interactive pixel art MCM room diorama — replaces AsciiHeader
// Objects are secretly clickable links to social profiles
---

<div class="desk-scene-wrap" role="banner" aria-label="Alexander Campos">
  <canvas id="desk-scene" aria-hidden="true"></canvas>
  <button id="theme-toggle" class="theme-toggle" aria-label="Toggle day/night mode" type="button">
    <svg class="theme-icon theme-icon--sun" width="12" height="12" viewBox="0 0 12 12" fill="none">
      <rect x="5" y="0" width="2" height="2" fill="currentColor"/>
      <rect x="5" y="10" width="2" height="2" fill="currentColor"/>
      <rect x="0" y="5" width="2" height="2" fill="currentColor"/>
      <rect x="10" y="5" width="2" height="2" fill="currentColor"/>
      <rect x="1" y="1" width="2" height="2" fill="currentColor"/>
      <rect x="9" y="1" width="2" height="2" fill="currentColor"/>
      <rect x="1" y="9" width="2" height="2" fill="currentColor"/>
      <rect x="9" y="9" width="2" height="2" fill="currentColor"/>
      <rect x="4" y="4" width="4" height="4" fill="currentColor"/>
    </svg>
    <svg class="theme-icon theme-icon--moon" width="12" height="12" viewBox="0 0 12 12" fill="none">
      <rect x="4" y="1" width="2" height="2" fill="currentColor"/>
      <rect x="6" y="1" width="2" height="2" fill="currentColor"/>
      <rect x="2" y="3" width="2" height="2" fill="currentColor"/>
      <rect x="1" y="5" width="2" height="2" fill="currentColor"/>
      <rect x="2" y="7" width="2" height="2" fill="currentColor"/>
      <rect x="4" y="9" width="2" height="2" fill="currentColor"/>
      <rect x="6" y="9" width="2" height="2" fill="currentColor"/>
      <rect x="8" y="7" width="2" height="2" fill="currentColor"/>
      <rect x="8" y="3" width="2" height="2" fill="currentColor"/>
    </svg>
  </button>
  <span class="ds-tooltip" id="ds-tooltip"></span>
</div>

<style>
  .desk-scene-wrap {
    position: relative;
    width: 100%;
    max-width: 720px;
    margin: 0 auto 0.5rem;
  }

  #desk-scene {
    display: block;
    width: 100%;
    height: auto;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    cursor: default;
  }

  .ds-tooltip {
    position: absolute;
    bottom: -20px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--gold-accent);
    letter-spacing: 0.1em;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
    white-space: nowrap;
  }

  .ds-tooltip.visible {
    opacity: 1;
  }

  .theme-toggle {
    position: absolute;
    bottom: 6px;
    right: 6px;
    width: 24px;
    height: 24px;
    background: transparent;
    border: 1px solid var(--white-15);
    padding: 5px;
    z-index: 2;
    color: var(--gold-accent);
    opacity: 0.6;
    transition: opacity 0.25s, border-color 0.25s;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 2px;
  }
  .theme-toggle:hover { opacity: 1; border-color: var(--gold-accent); }

  /* day mode: show moon (click to go night), hide sun */
  .theme-icon--moon { display: none; }
  [data-theme="dark"] .theme-icon--sun { display: none; }
  [data-theme="dark"] .theme-icon--moon { display: block; }

  @media (max-width: 480px) {
    .desk-scene-wrap {
      max-width: 100%;
    }
  }
</style>

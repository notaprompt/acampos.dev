---
import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<Page title="projects -- alexander campos" description="Guardian, ForgeFrame, MCP Memory Server, Resonance, Cipher.">
  <article>
    <h1>Projects</h1>

    <p>
      Everything here is documented honestly -- what I was trying to do, how I actually
      did it, where it falls short, and what I learned. The limitations section is not
      a formality. I put real ones there.
    </p>

    <div class="project-list">
      {projects.map(project => (
        <a href={`/projects/${project.slug}`} class="project-card">
          <div class="project-header">
            <h2>{project.data.title}</h2>
            <span class={`status status-${project.data.status}`}>{project.data.status}</span>
          </div>
          <p class="project-tagline">{project.data.tagline}</p>
          <div class="project-stack">
            {project.data.stack.map(tech => (
              <span class="tech">{tech}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </article>

  <script is:inline>
    console.log(
      '%c the layer stack: ',
      'color: #b8965a; font-family: monospace; font-size: 11px;'
    );
    console.log(
      '%c L4  Guardian Pro / ForgeFrame Enterprise  PROPRIETARY\n' +
      ' L3  ForgeFrame Core (routing, sessions)    AGPL\n' +
      ' L2  MCP Memory Server (the primitive)      MIT\n' +
      ' L1  MCP Protocol                           OPEN',
      'color: #E8DCC8; font-family: monospace; font-size: 10px;'
    );
  </script>
</Page>

<style>
  .project-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .project-card {
    display: block;
    position: relative;
    padding: 1.25rem;
    background: var(--depth-1);
    border: 1px solid var(--white-08);
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
  }

  .project-card::before,
  .project-card::after {
    content: '';
    position: absolute;
    width: 12px;
    height: 12px;
    opacity: 0;
    transition: opacity 0.15s ease;
    pointer-events: none;
  }

  .project-card::before {
    top: -2px;
    left: -2px;
    border-top: 2px solid var(--gold-accent);
    border-left: 2px solid var(--gold-accent);
  }

  .project-card::after {
    bottom: -2px;
    right: -2px;
    border-bottom: 2px solid var(--gold-accent);
    border-right: 2px solid var(--gold-accent);
  }

  .project-card:hover {
    border-color: var(--gold-accent);
    background: var(--depth-2);
  }

  @media (hover: hover) {
    .project-card:hover::before,
    .project-card:hover::after {
      opacity: 1;
    }
  }

  .project-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .project-header h2 {
    font-size: 1.15rem;
    margin: 0;
    color: var(--glow-hot);
  }

  .status {
    font-family: var(--mono);
    font-size: 0.65rem;
    padding: 0.15em 0.5em;
    border: 2px solid;
    border-radius: 2px;
    image-rendering: pixelated;
    box-shadow: inset 1px 1px 0 rgba(255, 255, 255, 0.1);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .status-active {
    color: var(--alive);
    border-color: var(--alive);
  }

  .status-shipped {
    color: var(--gold-accent);
    border-color: var(--gold-accent);
  }

  .status-concept {
    color: var(--white-45);
    border-color: var(--white-30);
  }

  .project-tagline {
    color: var(--glow);
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tech {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--white-45);
    background: var(--depth-2);
    padding: 0.15em 0.4em;
    border: 1px solid var(--white-08);
  }
</style>

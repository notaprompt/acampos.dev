---
// FIGlet "Small" font — pre-rendered, static
const art = `    _   _                    _
   / \\ | | _____  ____ _ _ _| |__   ___ _ __
  / _ \\| |/ _ \\ \\/ / _\` | '_ \\ / _\` / _ \\ '__|
 / ___ \\ |  __/>  < (_| | | | | (_| |  __/ |
/_/   \\_\\_|\\___/_/\\_\\__,_|_| |_|\\__,_|\\___|_|

  ___
 / __|__ _ _ __ _ __  ___  ___
| (__/ _\` | '  \\| '_ \\/ _ \\(_-<
 \\___\\__,_|_|_|_| .__/\\___//__/
                 |_|`;
---

<div class="ascii-header" role="banner" aria-label="Alexander Campos">
<pre aria-hidden="true" set:html={art} />
</div>

<style>
  .ascii-header {
    margin-bottom: 0.5rem;
  }

  .ascii-header pre {
    font-family: var(--mono);
    font-size: 0.65rem;
    line-height: 1.15;
    color: var(--gold-accent);
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    white-space: pre;
    overflow: hidden;
    user-select: none;
  }

  @media (max-width: 600px) {
    .ascii-header pre {
      font-size: 0.4rem;
    }
  }
</style>

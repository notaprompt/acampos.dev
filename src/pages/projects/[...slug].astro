---
import Page from '../../layouts/Page.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Page
  title={`${entry.data.title} -- alexander campos`}
  description={entry.data.tagline}
  ogType="article"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareSourceCode",
    "name": entry.data.title,
    "description": entry.data.tagline,
    "url": `https://campos.works/projects/${entry.slug}`,
    ...(entry.data.repo ? { "codeRepository": entry.data.repo } : {}),
    ...(entry.data.demo ? { "targetProduct": { "@type": "WebApplication", "url": entry.data.demo } } : {}),
    "programmingLanguage": entry.data.stack,
    "author": {
      "@type": "Person",
      "name": "Alexander Campos",
      "url": "https://campos.works"
    },
    "creativeWorkStatus": entry.data.status === 'shipped' ? 'Published' : entry.data.status === 'active' ? 'In development' : 'Concept'
  })} />

  <article class="project-detail">
    <header class="project-header">
      <h1>{entry.data.title}</h1>
      <p class="tagline">{entry.data.tagline}</p>
      <div class="meta">
        <span class={`status status-${entry.data.status}`}>{entry.data.status}</span>
        <div class="stack">
          {entry.data.stack.map(tech => (
            <span class="tech">{tech}</span>
          ))}
        </div>
        {entry.data.repo && (
          <a href={entry.data.repo} class="repo-link" target="_blank" rel="noopener noreferrer">
            source >>
          </a>
        )}
        {entry.data.demo && (
          <a href={entry.data.demo} class="demo-link" target="_blank" rel="noopener noreferrer">
            launch demo >>
          </a>
        )}
        {entry.data.hidden_demo && (
          <button id="hidden-demo-btn" class="demo-link demo-link--hidden" type="button">
            launch demo >>
          </button>
        )}
      </div>
    </header>

    {entry.data.image && (
      <div class="project-screenshot">
        <img src={entry.data.image} alt={`${entry.data.title} screenshot`} loading="lazy" />
      </div>
    )}

    <div class="project-content">
      <Content />
    </div>

    <nav class="back-nav">
      <a href="/projects">&lt;&lt; all projects</a>
    </nav>
  </article>
</Page>

<style>
  .project-detail {
    max-width: 100%;
  }

  .project-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--white-08);
  }

  .tagline {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--white-60);
    margin-bottom: 1rem;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .status {
    font-family: var(--mono);
    font-size: 0.65rem;
    padding: 0.15em 0.5em;
    border: 1px solid;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .status-active { color: var(--alive); border-color: var(--alive); }
  .status-shipped { color: var(--gold-accent); border-color: var(--gold-accent); }
  .status-concept { color: var(--white-45); border-color: var(--white-30); }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tech {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--white-45);
    background: var(--depth-2);
    padding: 0.15em 0.4em;
    border: 1px solid var(--white-08);
  }

  .repo-link,
  .demo-link {
    font-family: var(--mono);
    font-size: 0.75rem;
  }

  .demo-link {
    color: var(--alive);
  }

  .project-content :global(h2) {
    margin-top: 2.5rem;
  }

  .project-content :global(pre) {
    font-size: 0.8rem;
  }

  .project-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .back-nav {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--white-08);
  }

  .back-nav a {
    font-family: var(--mono);
    font-size: 0.8rem;
  }

  .project-screenshot {
    margin-bottom: 2rem;
    border: 1px solid var(--white-08);
    transition: border-color 0.2s;
  }

  .project-screenshot:hover {
    border-color: var(--gold-accent);
  }

  .project-screenshot img {
    width: 100%;
    display: block;
  }

  /* hidden demo button — looks like a real link */
  .demo-link--hidden {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  /* scroll overlay */
  #scroll-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }

  #scroll-overlay.open {
    display: flex;
  }

  #scroll-popup {
    width: min(420px, 90vw);
    animation: unroll 0.45s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    transform-origin: top center;
  }

  @keyframes unroll {
    from {
      opacity: 0;
      clip-path: inset(50% 0 50% 0);
    }
    to {
      opacity: 1;
      clip-path: inset(0% 0 0% 0);
    }
  }

  .scroll-cap {
    height: 18px;
    background: var(--gold-accent);
    border-radius: 3px;
    opacity: 0.85;
  }

  .scroll-body {
    background: #0e0b07;
    border-left: 1px solid var(--gold-accent);
    border-right: 1px solid var(--gold-accent);
    padding: 2.5rem 2rem;
    text-align: center;
  }

  .scroll-body p {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--glow);
    line-height: 1.8;
    margin: 0;
  }

  .scroll-body p + p {
    margin-top: 1.25rem;
    color: var(--white-45);
    font-size: 0.75rem;
  }
</style>

<!-- hidden demo scroll — only rendered when hidden_demo is true -->
{entry.data.hidden_demo && (
  <div id="scroll-overlay" role="dialog" aria-modal="true" aria-label="Hidden demo">
    <div id="scroll-popup">
      <div class="scroll-cap"></div>
      <div class="scroll-body">
        <p>this link is hidden.</p>
        <p>if you were this link, where would you hide?</p>
      </div>
      <div class="scroll-cap"></div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var btn = document.getElementById('hidden-demo-btn');
      var overlay = document.getElementById('scroll-overlay');
      if (!btn || !overlay) return;

      btn.addEventListener('click', function () {
        overlay.classList.add('open');
      });

      overlay.addEventListener('click', function () {
        overlay.classList.remove('open');
      });

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') overlay.classList.remove('open');
      });
    })();
  </script>
)}

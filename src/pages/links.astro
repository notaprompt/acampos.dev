---
import Page from '../layouts/Page.astro';

const links = [
  { label: 'GitHub', url: 'https://github.com/notaprompt', desc: 'open source' },
  { label: 'Reframed', url: 'https://reframed.works', desc: 'resume analysis' },
  { label: 'Substack', url: 'https://substack.com/@alexinthefield', desc: 'writing' },
  { label: 'LinkedIn', url: 'https://www.linkedin.com/in/alexander-d-campos/', desc: 'professional' },
];
---

<Page title="links -- alexander campos" description="Curated links and 88x31 buttons.">
  <article>
    <h1>Links</h1>

    <p>Things I use, things I read, things I think are worth your time.</p>

    <div class="button-grid">
      {links.map(link => (
        <a href={link.url} class="button-88x31" target="_blank" rel="noopener noreferrer">
          <span class="btn-label">{link.label}</span>
          <span class="btn-desc">{link.desc}</span>
        </a>
      ))}
    </div>

    <hr />

    <h2><a href="#" data-influences style="color: var(--glow); text-decoration: none; border-bottom: none;">Influences</a></h2>
    <p class="influences-sub">People whose work shaped how I think about what I build. <a href="#" data-influences style="color: var(--gold-accent); border-bottom: 1px dashed var(--gold-accent);">Browse</a>.</p>
  </article>
</Page>

<style>
  .button-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1.5rem 0;
  }

  .button-88x31 {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 88px;
    height: 31px;
    background: var(--depth-2);
    border: 1px solid var(--white-08);
    font-family: var(--mono);
    text-decoration: none;
    overflow: hidden;
    transition: border-color 0.2s, background 0.2s;
  }

  .button-88x31:hover {
    border-color: var(--gold-accent);
    background: var(--depth-3);
  }

  .btn-label {
    font-size: 0.55rem;
    color: var(--gold-accent);
    line-height: 1;
    letter-spacing: 0.05em;
  }

  .btn-desc {
    font-size: 0.4rem;
    color: var(--white-30);
    line-height: 1;
  }

  @media (hover: hover) {
    .button-88x31:hover::after {
      content: '';
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        to bottom,
        transparent 0px,
        transparent 1px,
        rgba(0, 0, 0, 0.08) 1px,
        rgba(0, 0, 0, 0.08) 2px
      );
      pointer-events: none;
    }
  }

  @media (max-width: 480px) {
    .button-88x31 {
      width: 120px;
      height: 44px;
    }
    .btn-label {
      font-size: 0.7rem;
    }
    .btn-desc {
      font-size: 0.5rem;
    }
  }

  @media (min-width: 1400px) {
    .button-88x31 {
      width: 132px;
      height: 46px;
    }
    .btn-label {
      font-size: 0.75rem;
    }
    .btn-desc {
      font-size: 0.55rem;
    }
  }

  .influences-sub {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--white-30);
  }

</style>

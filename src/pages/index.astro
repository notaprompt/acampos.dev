---
import Page from '../layouts/Page.astro';
import HitCounter from '../components/HitCounter.astro';
---

<Page title="alexander campos" description="Hand-built personal site. building things to protect how we think.">
  <section class="splash">
    <p class="tagline">building things to protect how we think.</p>

    <marquee class="retro-marquee" behavior="scroll" direction="left" scrollamount="2">
      welcome to my corner of the internet -- last updated march 2026 -- yes this is a marquee tag, it stays
    </marquee>

    <div class="intro">
      <p>
        I'm Alex. I work in regulated finance during the day and build local intelligence
        infrastructure at night.
      </p>
      <p>
        Right now I'm building <a href="/projects/forgeframe">ForgeFrame</a> (local-first
        infrastructure for routing, memory, and provenance)
        and <a href="/projects/guardian">Guardian</a> (a desktop app that detects when
        language models subtly rewrite how you describe yourself). I also <a href="/writing">write about it</a>.
        This site is hand-built. View source if you're curious what that means.
      </p>
    </div>

    <nav class="enter-nav" aria-label="Quick links">
      <a href="/projects" class="enter-link">projects >></a>
      <a href="/about" class="enter-link">about me >></a>
      <a href="/writing" class="enter-link">writing >></a>
    </nav>

    <div class="counter-row">
      <HitCounter />
    </div>
  </section>

  <script is:inline>
    console.log(
      '%c you are at the front door. ',
      'color: #b8965a; font-family: monospace; font-size: 11px;'
    );
  </script>

  <script src="../islands/hit-counter.js"></script>
</Page>

<style>
  .splash {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .tagline {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--white-60);
    margin-bottom: 0;
  }

  .intro p {
    color: var(--glow);
    font-size: 1rem;
  }

  .enter-nav {
    display: flex;
    gap: 2rem;
  }

  .enter-link {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--gold-accent);
    border-bottom: none;
  }

  .enter-link:hover {
    color: var(--glow-hot);
    border-bottom: none;
    transition: none;
  }

  .counter-row {
    padding-top: 1rem;
    border-top: 1px solid var(--white-08);
  }

  /* ── Pixel Grid Hover Texture ── */
  @media (hover: hover) {
    .enter-link:hover {
      background-image: url("data:image/svg+xml,%3Csvg width='2' height='2' xmlns='http://www.w3.org/2000/svg'%3E%3Crect width='1' height='1' fill='white' fill-opacity='0.04'/%3E%3C/svg%3E");
      background-size: 2px 2px;
      transition: none;
    }
  }
</style>

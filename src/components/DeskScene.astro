---
// Interactive pixel art MCM room diorama — replaces AsciiHeader
// Objects are secretly clickable links to social profiles
---

<div class="desk-scene-wrap" role="banner" aria-label="Alexander Campos">
  <canvas id="desk-scene" aria-hidden="true"></canvas>
  <button id="theme-toggle" class="theme-toggle" aria-label="Toggle day/night mode" type="button">
    <svg class="theme-icon theme-icon--sun" width="10" height="10" viewBox="0 0 12 12" fill="none">
      <rect x="5" y="0" width="2" height="2" fill="currentColor"/>
      <rect x="5" y="10" width="2" height="2" fill="currentColor"/>
      <rect x="0" y="5" width="2" height="2" fill="currentColor"/>
      <rect x="10" y="5" width="2" height="2" fill="currentColor"/>
      <rect x="1" y="1" width="2" height="2" fill="currentColor"/>
      <rect x="9" y="1" width="2" height="2" fill="currentColor"/>
      <rect x="1" y="9" width="2" height="2" fill="currentColor"/>
      <rect x="9" y="9" width="2" height="2" fill="currentColor"/>
      <rect x="4" y="4" width="4" height="4" fill="currentColor"/>
    </svg>
    <span class="theme-slash">/</span>
    <svg class="theme-icon theme-icon--moon" width="10" height="10" viewBox="0 0 12 12" fill="none">
      <!-- crescent — opens left, angled up, 2px thick body -->
      <rect x="7" y="0" width="2" height="1" fill="currentColor"/>
      <rect x="8" y="1" width="2" height="1" fill="currentColor"/>
      <rect x="9" y="2" width="2" height="2" fill="currentColor"/>
      <rect x="8" y="4" width="2" height="2" fill="currentColor"/>
      <rect x="7" y="6" width="2" height="2" fill="currentColor"/>
      <rect x="6" y="8" width="2" height="1" fill="currentColor"/>
      <rect x="5" y="9" width="2" height="1" fill="currentColor"/>
      <rect x="4" y="10" width="2" height="1" fill="currentColor"/>
    </svg>
  </button>
  <span class="ds-tooltip" id="ds-tooltip"></span>
</div>

<style>
  .desk-scene-wrap {
    position: relative;
    width: 100%;
    max-width: 720px;
    margin: 0 auto 0;
  }

  #desk-scene {
    display: block;
    width: 100%;
    height: auto;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    cursor: default;
  }

  .ds-tooltip {
    position: absolute;
    bottom: -20px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--gold-accent);
    letter-spacing: 0.1em;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
    white-space: nowrap;
  }

  .ds-tooltip.visible {
    opacity: 1;
  }

  .theme-toggle {
    position: absolute;
    bottom: 6px;
    right: 6px;
    background: transparent;
    border: none;
    padding: 4px;
    z-index: 2;
    opacity: 0.75;
    transition: opacity 0.25s;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 2px;
  }
  .theme-toggle:hover { opacity: 1; }

  .theme-slash {
    font-family: var(--mono);
    font-size: 0.55rem;
    color: var(--white-20);
    line-height: 1;
    user-select: none;
  }

  /* Both icons always visible — active one glows, inactive dims */
  .theme-icon { transition: color 0.3s, opacity 0.3s, filter 0.3s; }
  /* Day mode: sun active (warm gold glow), moon dimmed but visible white */
  .theme-icon--sun { color: #d4a030; opacity: 1; filter: drop-shadow(0 0 3px #d4a030); }
  .theme-icon--moon { color: #d0d0d0; opacity: 0.6; filter: none; }
  /* Night mode: moon active (white glow), sun dimmed */
  [data-theme="dark"] .theme-icon--sun { color: #555; opacity: 0.4; filter: none; }
  [data-theme="dark"] .theme-icon--moon { color: #ffffff; opacity: 1; filter: drop-shadow(0 0 4px rgba(255,255,255,0.7)); }

  @media (max-width: 480px) {
    .desk-scene-wrap {
      max-width: 100%;
    }
  }
</style>

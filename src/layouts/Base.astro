---
import '../styles/global.css';
import '../styles/retro.css';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  ogType?: string;
}

const { title, description = 'Hand-built personal site of Alexander Campos.', ogType = 'website' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!--
  ╔══════════════════════════════════════════════════════════════╗
  ║                                                              ║
  ║   alexander campos — campos.works                            ║
  ║                                                              ║
  ║   surface: a hand-built 2003 homepage                        ║
  ║   substrate: WebGL2 ASCII shaders, reaction-diffusion,       ║
  ║              procedural audio, generative systems             ║
  ║                                                              ║
  ║   view-source is a feature, not a vulnerability.              ║
  ║                                                              ║
  ║   stack: astro (static), vanilla JS islands, WebGL2,          ║
  ║          web workers, web audio API                           ║
  ║                                                              ║
  ║   no frameworks were harmed in the making of this site.       ║
  ║                                                              ║
  ╚══════════════════════════════════════════════════════════════╝
-->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="generator" content={Astro.generator} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <!-- Blocking theme init — prevents flash of wrong theme -->
  <script is:inline>
    (function(){
      var t = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>

  <ViewTransitions />
  <title>{title}</title>
  <meta name="description" content={description} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={new URL('/og-image.png', Astro.site)} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL('/og-image.png', Astro.site)} />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Alexander Campos",
    "url": Astro.site?.toString(),
    "jobTitle": "Independent Researcher & Engineer",
    "description": "Builds local-first cognitive infrastructure. ForgeFrame (MCP memory server), Reframed (resume analysis), Guardian Labs (neuroscience research).",
    "sameAs": [
      "https://github.com/notaprompt",
      "https://linkedin.com/in/alexander-d-campos",
      "https://reframed.works",
      "https://guardian-labs.org",
      "https://substack.com/@alexinthefield"
    ],
    "knowsAbout": [
      "local-first AI infrastructure",
      "Model Context Protocol",
      "persistent memory for AI agents",
      "cognitive architecture",
      "resting-state fMRI",
      "transdiagnostic psychiatry",
      "identity modeling",
      "identity modeling"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer service",
      "email": "alex@campos.works",
      "url": "https://cal.com/alexander-campos-yrnz8m/30min",
      "availableLanguage": "English"
    }
  })} />

  <!-- ForgeFrame Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "ForgeFrame",
    "description": "Open-source persistent memory for AI agents. MCP server with SQLite + FTS5, strength decay, constitutional principles that never decay.",
    "url": "https://github.com/notaprompt/forgeframe",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "macOS, Linux, Windows",
    "author": {
      "@type": "Person",
      "name": "Alexander Campos",
      "url": "https://campos.works"
    },
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock"
    },
    "installUrl": "https://www.npmjs.com/package/@forgeframe/server"
  })} />

  <!-- Services Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Alexander Campos",
    "url": "https://campos.works/services",
    "provider": {
      "@type": "Person",
      "name": "Alexander Campos",
      "url": "https://campos.works"
    },
    "areaServed": "Worldwide",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Services",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Full Online Presence Build",
            "description": "Website, scheduling, calendar, contact forms, SEO, automations for small businesses."
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Agentic SEO & AI Discoverability",
            "description": "Structured data, agent discovery endpoints, machine-readable profiles."
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "AI Cost Optimization",
            "description": "Model routing and tiered dispatch. Cuts API spend 40-60%."
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Custom AI Automation",
            "description": "Agent orchestration, scheduling, monitoring, reporting, intake flows."
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Claude Code & MCP Setup",
            "description": "Custom MCP servers, persistent memory, team configurations for enterprise Claude deployments."
          }
        }
      ]
    }
  })} />

  <!-- Fonts -->
  <link rel="preload" href="/fonts/cormorant-garamond-400.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/cormorant-garamond-600.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/jetbrains-mono-400.woff2" as="font" type="font/woff2" crossorigin />

  <style is:inline>
    @font-face {
      font-family: 'Cormorant Garamond';
      src: url('/fonts/cormorant-garamond-400.woff2') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Cormorant Garamond';
      src: url('/fonts/cormorant-garamond-600.woff2') format('woff2');
      font-weight: 600;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'JetBrains Mono';
      src: url('/fonts/jetbrains-mono-400.woff2') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
  </style>

  <!-- Styles imported via Astro frontmatter -->
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>

  <!-- ASCII background canvas — reaction-diffusion substrate -->
  <canvas id="ascii-bg" aria-hidden="true"></canvas>

  <slot />

  <!-- Atmospheric overlays -->
  <div class="grain" aria-hidden="true"></div>
  <div class="vignette" aria-hidden="true"></div>

  <!-- Cursor trail canvas -->
  <canvas id="cursor-trail" aria-hidden="true"></canvas>

  <!-- Console greeting -->
  <script is:inline>
    console.log(
      '%c alexander campos ',
      'background: #b8965a; color: #050505; padding: 4px 12px; font-family: Georgia, serif; font-size: 14px;'
    );
    console.log(
      '%c 2003 surface. 2026 substrate. you found the good part. ',
      'color: #E8DCC8; font-family: monospace; font-size: 11px;'
    );
    console.log(
      '%c astro + vanilla JS + WebGL2 + web workers. no frameworks were harmed. ',
      'color: #555; font-family: monospace; font-size: 10px;'
    );
  </script>

  <!-- Persistent audio element — survives page transitions -->
  <audio id="music-player-audio" preload="metadata" transition:persist="audio"></audio>

  <!-- Islands — loaded after page is interactive -->
  <script is:inline src="/islands/desk-scene.js"></script>
  <script is:inline src="/islands/ascii-bg.js"></script>
  <script is:inline src="/islands/cursor-trail.js"></script>
  <script is:inline src="/islands/konami.js"></script>
  <script is:inline src="/islands/music-panel.js"></script>
  <script is:inline src="/islands/auto-profile.js"></script>
  <script is:inline src="/islands/playlist-admin.js"></script>
  <script is:inline src="/islands/audio-bridge.js"></script>
  <script is:inline src="/islands/influences.js"></script>
  <script is:inline src="/islands/assistant.js"></script>

  <!-- Theme toggle handler -->
  <script is:inline>
    (function() {
      function wireToggle() {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', function() {
          var current = document.documentElement.getAttribute('data-theme') || 'light';
          var next = current === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
          if (window.__setDeskSceneTheme) window.__setDeskSceneTheme(next);
          if (window.__setAsciiTheme) window.__setAsciiTheme(next === 'dark' ? 1.0 : 0.0);
        });
      }
      wireToggle();
      document.addEventListener('astro:after-swap', function() {
        setTimeout(wireToggle, 200);
      });
    })();
  </script>

  <!-- Re-run islands after View Transition page swaps -->
  <script is:inline>
    document.addEventListener('astro:after-swap', function () {
      // Clean up island instances before re-init
      if (window.__asciiBgCleanup) window.__asciiBgCleanup();
      if (window.__musicPanelCleanup) window.__musicPanelCleanup();
      // Clear all init guards so scripts can rebuild DOM
      window.__deskSceneInit = false;
      window.__asciiBgInit = false;
      window.__cursorTrailInit = false;
      window.__konamiInit = false;
      window.__musicPanelInit = false;
      window.__audioBridgeInit = false;
      window.__ambientInit = false;
      window.__oliverInit = false;
      window.__influencesInit = false;
      // Re-apply theme
      var t = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', t);
      // Re-execute island scripts
      var islands = [
        '/islands/desk-scene.js', '/islands/ascii-bg.js',
        '/islands/cursor-trail.js', '/islands/konami.js',
        '/islands/music-panel.js', '/islands/playlist-admin.js', '/islands/audio-bridge.js',
        '/islands/influences.js', '/islands/assistant.js'
      ];
      islands.forEach(function (src) {
        var s = document.createElement('script');
        s.src = src + '?t=' + Date.now();
        document.body.appendChild(s);
      });
    });
  </script>
</body>
</html>

<style is:global>
  #ascii-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  #cursor-trail {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9996;
    pointer-events: none;
  }
</style>

---
import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';
import Wtf from '../../components/Wtf.astro';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map(essay => ({
    params: { slug: essay.slug },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content } = await essay.render();
---

<Page title={`${essay.data.title} -- alexander campos`} description={essay.data.subtitle}>
  <article class="essay">
    <header class="essay-header">
      <h1>{essay.data.title}</h1>
      <p class="subtitle">{essay.data.subtitle}</p>
      <span class="date">{essay.data.date}</span>
    </header>
    <div class="essay-body">
      <Content components={{ Wtf }} />
    </div>
    <footer class="essay-footer">
      <a href="/writing">&larr; back to writing</a>
    </footer>
  </article>
</Page>

<style>
  .essay-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--white-08);
  }

  .essay-header h1 {
    margin-bottom: 0.5rem;
  }

  .subtitle {
    font-family: var(--body);
    font-size: 1rem;
    color: var(--white-60);
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }

  .date {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--white-45);
  }

  .essay-body {
    line-height: 1.7;
  }

  .essay-body :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .essay-body :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .essay-body :global(p) {
    margin-bottom: 1.25rem;
  }

  .essay-body :global(blockquote) {
    border-left: 2px solid var(--gold-accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--white-60);
    font-style: italic;
  }

  .essay-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--white-08);
  }

  .essay-footer a {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--gold-accent);
  }
</style>

---
import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const micro = (await getCollection('micro')).filter(m => !m.data.hidden).sort((a, b) => a.data.order - b.data.order);
---

<Page title="projects -- alexander campos" description="Reframed, ForgeFrame, Distillery, Cipher.">
  <article>
    <h1>Projects</h1>

    <p>
      What I build, why, and what doesn't work yet. The limitations sections are honest.
    </p>

    <div class="project-list">
      {projects.map(project => (
        <div class="project-card">
          <div class="project-header">
            <h2><a href={`/projects/${project.slug}`} class="card-main-link">{project.data.title}</a></h2>
            <span class={`status status-${project.data.status}`}>{project.data.status}</span>
          </div>
          <p class="project-tagline">{project.data.tagline}</p>
          {project.data.repo && (
            <a href={project.data.repo} class="card-repo-link" target="_blank" rel="noopener noreferrer">repo</a>
          )}
          <div class="project-stack">
            {project.data.stack.map(tech => (
              <span class="tech">{tech}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    {micro.length > 0 && (
      <div class="micro-section">
        <h2 class="micro-heading">Micro</h2>
        <p class="micro-desc">Small tools. Single-purpose. No ceremony.</p>
        <div class="micro-list">
          {micro.map(m => (
            <div class="micro-card">
              <div class="micro-header">
                <h3>{m.data.title}</h3>
                <span class={`status status-${m.data.status}`}>{m.data.status}</span>
              </div>
              <p class="micro-tagline">{m.data.tagline}</p>
              <div class="micro-links">
                {m.data.repo && <a href={m.data.repo} class="micro-link">repo</a>}
                {m.data.download && <a href={m.data.download} class="micro-link">download</a>}
              </div>
              <div class="project-stack">
                {m.data.stack.map(tech => (
                  <span class="tech">{tech}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </article>

  <script is:inline>
    console.log(
      '%c the layer stack: ',
      'color: #b8965a; font-family: monospace; font-size: 11px;'
    );
    console.log(
      '%c L3  ForgeFrame Core (routing, sessions)    AGPL\n' +
      ' L2  MCP Memory Server (the primitive)      MIT\n' +
      ' L1  MCP Protocol                           OPEN',
      'color: #E8DCC8; font-family: monospace; font-size: 10px;'
    );
  </script>
</Page>

<style>
  .project-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .project-card {
    display: block;
    position: relative;
    padding: 1.25rem;
    background: var(--depth-1);
    border: 1px solid var(--white-08);
    transition: border-color 0.2s, background 0.2s;
  }

  .project-card::before,
  .project-card::after {
    content: '';
    position: absolute;
    width: 12px;
    height: 12px;
    opacity: 0;
    transition: opacity 0.15s ease;
    pointer-events: none;
  }

  .project-card::before {
    top: -2px;
    left: -2px;
    border-top: 2px solid var(--gold-accent);
    border-left: 2px solid var(--gold-accent);
  }

  .project-card::after {
    bottom: -2px;
    right: -2px;
    border-bottom: 2px solid var(--gold-accent);
    border-right: 2px solid var(--gold-accent);
  }

  .project-card:hover {
    border-color: var(--gold-accent);
    background: var(--depth-2);
  }

  @media (hover: hover) {
    .project-card:hover::before,
    .project-card:hover::after {
      opacity: 1;
    }
  }

  /* stretch link — covers entire card, sits below repo link */
  .card-main-link {
    color: inherit;
    text-decoration: none;
  }

  .card-main-link::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .project-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .project-header h2 {
    font-size: 1.15rem;
    margin: 0;
    color: var(--glow-hot);
  }

  .status {
    font-family: var(--mono);
    font-size: 0.65rem;
    padding: 0.15em 0.5em;
    border: 2px solid;
    border-radius: 2px;
    image-rendering: pixelated;
    box-shadow: inset 1px 1px 0 rgba(255, 255, 255, 0.1);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .status-active {
    color: var(--alive);
    border-color: var(--alive);
  }

  .status-shipped {
    color: var(--gold-accent);
    border-color: var(--gold-accent);
  }

  .status-concept {
    color: var(--white-45);
    border-color: var(--white-30);
  }

  .project-tagline {
    color: var(--glow);
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }

  .card-repo-link {
    display: inline-block;
    position: relative;
    z-index: 1;
    margin-bottom: 0.6rem;
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--gold-accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }

  .card-repo-link:hover {
    border-bottom-color: var(--gold-accent);
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tech {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--white-45);
    background: var(--depth-2);
    padding: 0.15em 0.4em;
    border: 1px solid var(--white-08);
  }

  .micro-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--white-08);
  }

  .micro-heading {
    font-size: 1rem;
    color: var(--white-45);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  .micro-desc {
    font-size: 0.8rem;
    color: var(--white-30);
    margin-bottom: 1.25rem;
  }

  .micro-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .micro-card {
    padding: 1rem;
    background: var(--depth-1);
    border: 1px solid var(--white-08);
  }

  .micro-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.35rem;
  }

  .micro-header h3 {
    font-size: 0.95rem;
    margin: 0;
    color: var(--glow);
  }

  .micro-tagline {
    color: var(--white-45);
    font-size: 0.8rem;
    margin-bottom: 0.5rem;
  }

  .micro-links {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .micro-link {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--gold-accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }

  .micro-link:hover {
    border-bottom-color: var(--gold-accent);
  }

</style>

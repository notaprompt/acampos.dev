---
import Page from '../layouts/Page.astro';

const links = [
  { label: 'GitHub', url: 'https://github.com/notaprompt', desc: 'open source' },
  { label: 'Substack', url: 'https://substack.com/@alexinthefield', desc: 'writing' },
  { label: 'LinkedIn', url: 'https://www.linkedin.com/in/alexander-d-campos/', desc: 'professional' },
  { label: 'Guardian', url: 'https://github.com/notaprompt/guardian-ui-scaffold', desc: 'desktop workspace' },
  { label: 'ForgeFrame', url: 'https://github.com/notaprompt', desc: 'local infrastructure' },
  { label: 'MCP Spec', url: 'https://modelcontextprotocol.io', desc: 'protocol' },
];
---

<Page title="links -- alexander campos" description="Curated links and 88x31 buttons.">
  <article>
    <h1>Links</h1>

    <p>Things I use, things I read, things I think are worth your time. The 88x31 buttons are non-negotiable.</p>

    <div class="button-grid">
      {links.map(link => (
        <a href={link.url} class="button-88x31" target="_blank" rel="noopener noreferrer">
          <span class="btn-label">{link.label}</span>
          <span class="btn-desc">{link.desc}</span>
        </a>
      ))}
    </div>

    <hr />

    <h2>Influences</h2>
    <ul>
      <li>Ibn Khaldun -- behavioral observation as structural analysis</li>
      <li>Christopher Alexander -- patterns that generate life in systems</li>
      <li>Norbert Wiener -- cybernetics, the human use of human beings</li>
      <li>Andrej Karpathy -- think before coding, simplicity first</li>
      <li>Paul Graham -- essays, writing clearly, building things</li>
    </ul>
  </article>
</Page>

<style>
  .button-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1.5rem 0;
  }

  .button-88x31 {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 88px;
    height: 31px;
    background: var(--depth-2);
    border: 1px solid var(--white-08);
    font-family: var(--mono);
    text-decoration: none;
    overflow: hidden;
    transition: border-color 0.2s, background 0.2s;
  }

  .button-88x31:hover {
    border-color: var(--gold-accent);
    background: var(--depth-3);
  }

  .btn-label {
    font-size: 0.55rem;
    color: var(--gold-accent);
    line-height: 1;
    letter-spacing: 0.05em;
  }

  .btn-desc {
    font-size: 0.4rem;
    color: var(--white-30);
    line-height: 1;
  }

  @media (hover: hover) {
    .button-88x31:hover::after {
      content: '';
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        to bottom,
        transparent 0px,
        transparent 1px,
        rgba(0, 0, 0, 0.08) 1px,
        rgba(0, 0, 0, 0.08) 2px
      );
      pointer-events: none;
    }
  }
</style>

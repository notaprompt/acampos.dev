---
const year = new Date().getFullYear();
---

<footer>
  <p class="copyright">alexander campos {year}. hand-built.</p>
  <p class="contact"><a href="mailto:alex@campos.works">alex@campos.works</a></p>
  <p class="guestbook-link"><a href="/guestbook">sign the guestbook</a></p>
  <p class="best-viewed">best viewed in a browser that respects view-source.</p>
</footer>

<style>
  footer {
    border-top: 2px dashed var(--white-08);
    padding-top: 1.5rem;
    margin-top: 3rem;
    text-align: center;
  }

  .copyright {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--white-30);
    margin-bottom: 0.25rem;
  }

  .contact {
    font-family: var(--mono);
    font-size: 0.7rem;
    margin-bottom: 0.25rem;
  }

  .contact a {
    color: var(--white-30);
    transition: color 0.2s;
  }

  .contact a:hover {
    color: var(--gold-accent);
  }

  .guestbook-link {
    font-family: var(--mono);
    font-size: 0.7rem;
    margin-bottom: 0.25rem;
  }

  .guestbook-link a {
    color: var(--gold-accent);
    border-bottom: 1px dashed var(--gold-accent);
    text-decoration: none;
    transition: color 0.2s;
  }

  .best-viewed {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--white-15);
    margin-bottom: 0;
  }
</style>

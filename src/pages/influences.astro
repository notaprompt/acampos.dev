---
import Page from '../layouts/Page.astro';

const sections = [
  {
    category: 'Systems & Cybernetics',
    people: [
      { name: 'Douglas Hofstadter', note: 'Self-reference as the mechanism by which meaning arises from formal systems. I build on the assumption that the loop is the thing, not a description of it.' },
      { name: 'Karl Friston', note: 'Every living system maintains itself by minimizing the distance between what it expects and what it encounters. This grounded the work in physics instead of metaphor.' },
      { name: 'Norbert Wiener', note: 'Cybernetics, and what happens when the feedback loop includes a human being.' },
      { name: 'Niklas Luhmann', note: 'How operationally closed systems stay coherent in overwhelming environments. He also proved it by writing seventy books with a box of index cards.' },
    ],
  },
  {
    category: 'Philosophy & Inner Life',
    people: [
      { name: 'Carl Jung', note: 'The process of becoming whole through what you\'d rather not look at.' },
      { name: 'Baruch Spinoza', note: 'Freedom as adequate understanding of what constrains you.' },
      { name: 'Marcus Aurelius', note: 'Governed an empire while writing private notes about governing himself. The notes lasted longer.' },
      { name: 'Augustine', note: 'Fought his way into a framework he didn\'t inherit and wrote the first honest autobiography.' },
      { name: 'Thomas Aquinas', note: 'Decisions belong at the lowest level competent to make them.' },
    ],
  },
  {
    category: 'History & Power',
    people: [
      { name: 'Ibn Khaldun', note: 'Behavioral observation as structural analysis, written from inside the collapse.' },
      { name: 'Michel Foucault', note: 'Power operates through observation and classification, not force. Then everyone built the systems he warned about.' },
      { name: 'Peter Turchin', note: 'Elite overproduction precedes instability with uncomfortable regularity.' },
      { name: 'Jiang Xueqin', note: 'Overlays the 1930s on the present and asks students what rhymes.' },
    ],
  },
  {
    category: 'Engineering & Building',
    people: [
      { name: 'Christopher Alexander', note: 'Good structure isn\'t designed from above but generated by patterns that already know how to produce life.' },
      { name: 'Andrej Karpathy', note: 'Thinks before coding, ships simple things, and explains hard problems like someone who actually understands them.' },
      { name: 'Paul Graham', note: 'Writes clearly about building things, which turns out to be harder than building things.' },
      { name: 'Isaac Asimov', note: 'Imagined a science of historical prediction and then showed why it breaks when a single unpredictable actor appears.' },
    ],
  },
];
---

<Page title="influences -- alexander campos" description="People whose work shaped how I think about what I build.">
  <article>
    <h1>Influences</h1>

    <p class="influences-intro">
      People whose work shaped how I think about what I build.
      Not a reading list -- a map of the pressure points.
    </p>

    {sections.map(section => (
      <section class="influence-section">
        <h2>{section.category}</h2>
        <ul class="influence-list">
          {section.people.map(person => (
            <li>
              <strong>{person.name}</strong>
              <span class="influence-dash"> -- </span>
              <span class="influence-note">{person.note}</span>
            </li>
          ))}
        </ul>
      </section>
    ))}

    <hr />

    <section class="influence-section">
      <h2>Currently in rotation</h2>
      <ul class="rotation-list">
        <li>Shigeo Sekito</li>
        <li>Piero Piccioni</li>
        <li>Maison Music</li>
        <li>Nick Drake</li>
        <li>Blood Orange</li>
        <li>Mitu</li>
        <li>Lilen</li>
        <li>Latin Mafia</li>
        <li>54 Ultra</li>
        <li>A Flock of Seagulls</li>
        <li>Mojave</li>
        <li>Dean Blunt</li>
        <li>Panchiko</li>
        <li>Yves Tumor</li>
        <li>Aphex Twin</li>
        <li>Fontaines D.C.</li>
      </ul>
    </section>
  </article>

  <script is:inline>
    console.log(
      '%c you are reading the influences of someone who builds from first principles. ',
      'color: #E8DCC8; font-family: monospace; font-size: 11px;'
    );
  </script>
</Page>

<style>
  .influences-intro {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--white-60);
    margin-bottom: 2rem;
  }

  .influence-section {
    margin-bottom: 2rem;
  }

  .influence-list {
    list-style: none;
    padding-left: 0;
  }

  .influence-list li {
    color: var(--white-60);
    font-size: 0.95rem;
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .influence-list li strong {
    color: var(--glow);
    font-family: var(--serif);
    font-size: 1.05rem;
  }

  .influence-dash {
    color: var(--white-30);
  }

  .influence-note {
    color: var(--white-60);
  }

  .rotation-list {
    list-style: none;
    padding-left: 0;
    columns: 2;
    column-gap: 2rem;
  }

  .rotation-list li {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--white-45);
    margin-bottom: 0.4rem;
    break-inside: avoid;
  }
</style>
